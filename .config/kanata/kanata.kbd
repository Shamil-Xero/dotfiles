(defcfg
  process-unmapped-keys yes
)

(defsrc
  caps ralt
  '
)

(defalias
  ;; Caps Lock → Backspace (simple remap)
  cap bspc

  ;; Right Alt: tap = Space, hold = activate nav layer
  ralt (tap-hold 200 200 spc (layer-toggle nav))
)

(deflayer base
  @cap @ralt
  '
)

(deflayer nav
  _    _
  ret
)
