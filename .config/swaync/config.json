    // },
    "menubar": {
      "menu#power-buttons": {
        "label": "’Ćæ",
        "position": "right",
        "actions": [
          {
            "label": "’ĆĪ   Reboot",
            "command": "systemctl reboot"
          },
          {
            "label": "’ĆŻ   Lock",
            "command": "swaylock.sh"
          },
          {
            "label": "’éŗ   Logout",
            "command": "loginctl terminate-session ${XDG_SESSION_ID-}"
          },
          {
            "label": "’Ćæ   Shut down",
            "command": "systemctl poweroff"
          }
        ]
      },
      "menu#powermode-buttons": {
        "label": "’ā¦",
        "position": "right",
        "actions": [
          {
            "label": "Performance",
            "command": "tlpctl performance"
          },
          {
            "label": "Balanced",
            "command": "tlpctl balanced"
          },
          {
            "label": "Power-saver",
            "command": "tlpctl power-saver"
          }
        ]
      },
      "menu#screenshot-buttons": {
        "label": "’Ś┐",
        "position": "left",
        "actions": [
          {
            "label": "’Ś┐   Entire screen",
            "command": "swaync-client -cp && sleep 1 && hyprshot -m output"
          },
          {
            "label": "’Ś┐   Select a region",
            "command": "swaync-client -cp && sleep 1 && hyprshot -m region"
          },
          {
            "label": "’Ś┐   Open screenshot menu",
            "command": "swaync-client -cp && rofi-screenshot"
          },
          {
            "label": "’Ś┐   Open screenshot folder",
            "command": "exo-open $HYPRSHOT_DIR"
          }
        ]
      },
      "menu#screencast-buttons": {
        "label": "’ĆĮ",
        "position": "left",
        "actions": [
          {
            "label": "’ĆĮ   Entire screen",
            "command": "swaync-client -cp && sleep 1 && recording.sh toggle fullscreen"
          },
          {
            "label": "’ĆĮ   Select a region",
            "command": "swaync-client -cp && sleep 1 && recording.sh toggle region"
          },
          {
            "label": "’ĆĮ   Stop",
            "command": "swaync-client -cp && recording.sh stop"
          },
          {
            "label": "’ĆĮ   Open screencast folder",
            "command": "$XDG_VIDEOS_DIR/Screencasts"
          }
        ]
      }
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "¾░¢®",
          "command": "plasmawindowed org.kde.plasma.networkmanagement"
        },
        {
          "label": "’Ŗö",
          "command": "blueman-manager"
        },
        {
          "label": "’Ć©",
          "command": "pavucontrol"
        }
      ]
    }
  }
