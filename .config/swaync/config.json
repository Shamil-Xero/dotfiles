    "dnd": {
      "text": "Do Not Disturb"
    },
    "label": {
      "max-lines": 1,
      "text": "Control Center"
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 6
    },
    "backlight": {
      "label": "’ŚØ",
      "device": "nvidia_wmi_ec_backlight",
      "min": 10
    },
    "backlight#KB": {
      "label": "’ä£ ",
      "device": "*kbd_backlight",
      "subsystem": "leds"
    },
